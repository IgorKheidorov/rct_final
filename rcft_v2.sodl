  module NewsListPage:
    route = "/news"
    file = "src/app/news/page.tsx"
    title = "Новости — ФРКТ БГУ"
    meta_description = "Новости и события факультета радиофизики и компьютерных технологий БГУ."

    features:
      pagination = "12 материалов на страницу, URL: /news?page={n}"
      filters = "По тегу: все | абитуриентам | студентам | наука | события | медиа"
      layout = "Список карточек с датой, тегом, заголовком, excerpt, изображением (если есть)"

    content:
      source = "src/content/news/*.mdx — отсортировано по дате (убывание)"
      frontmatter:
        title: string          # обязательно
        date: "YYYY-MM-DD"     # обязательно
        tags: string[]         # enrollee | media | students | events | science
        excerpt: string        # обязательно
        image: string          # URL /images/news/... используемый как src в next/image (опционально)
        author: string         # (опционально)

    note = "Мигрировать все 21 статью из old_site/content/news/. Нормализовать slug (см. migration_notes.news_slug_normalization): строчные буквы, апострофы удалить, подчёркивания → дефисы."

  module NewsDetailPage:
    route = "/news/[slug]"
    file = "src/app/news/[slug]/page.tsx"
    content_pattern = "src/content/news/{slug}.mdx"
    title_template = "{title} — ФРКТ БГУ"
    static_params = "dynamic: все .mdx файлы в src/content/news/"

    layout:
      - "Breadcrumb: Главная / Новости / {title}"
      - "Теги (кликабельные → /news?tag={tag})"
      - "Дата публикации"
      - "Заголовок (Archivo Black)"
      - "Изображение (если есть, next/image)"
      - "MDX body (data-pagefind-body)"
      - "Блок «Похожие новости» — 3 статьи с тем же тегом"
      - "← Назад к новостям (href: /news)"


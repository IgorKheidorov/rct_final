    content_file = "src/content/contacts.mdx"
    title = "Контакты — ФРКТ БГУ"
    meta_description = "Адрес, телефоны, email и как добраться до факультета радиофизики и компьютерных технологий БГУ."
    source_url = "https://rct.bsu.by/contacts"

    sections:
      - id = "main"
        eyebrow = "// КОНТАКТЫ"
        heading = "Свяжитесь с нами"
        address = "220045, Республика Беларусь, г. Минск, ул. Академика Курчатова, 5"
        phone = "+375 (17) 209-58-18"
        phone_applicants = "+375 (17) 209-58-18"
        email = "rct@bsu.by"
        dean:
          name = "Ушаков Дмитрий Владимирович"
          title = "Декан, д-р физ.-мат. наук, доцент"
          phone = "+375 (17) 209-59-03"
          email = "ushakovdv@bsu.by"
          photo = "/images/dean_ushakov.jpg"

      - id = "map"
        component = "MapEmbed"
        note = "Yandex Maps iframe или статичное изображение карты. Точка: Минск, ул. Академика Курчатова, 5"
        fallback_image = "/images/map_faculty.jpg"
        yandex_maps_url = "https://yandex.by/maps/?pt=27.477,53.857&z=16&l=map"

      - id = "directions"
        anchor = "directions"
        eyebrow = "// КАК ДОБРАТЬСЯ"
        heading = "Транспорт"
        bus:
          - { routes: "№47с", from: "Ж/д вокзал (ост. «Вокзал»)", stop: "«Факультет радиофизики»" }
          - { routes: "№96, №132", stop: "«Факультет радиофизики»" }
          - { routes: "№28, №30ас, №97, №104, №114с, №134с, №144с", stop: "«Поворот к корпусу БГУ» / «ул. Наполеона»" }
          - { label: "Расписание автобусов Минска", href: "http://www.minsktrans.by/city/#minsk/bus", external: true }
        train:
          - { direction: "Направление Столбцы", stop: "ст. «Роща»" }
          - { label: "Расписание электричек", href: "http://rasp.rw.by/", external: true }
        metro:
          - { line: "Автозаводская линия (красная)", station: "«Малиновка» (конечная)", walk: "10 мин пешком мимо ОМА, к пешеходному переходу через МКАД" }

      - id = "social"
        eyebrow = "// МЫ В СОЦСЕТЯХ"
        items:
          - { platform: "VKontakte", url: "https://vk.com/rfikt_bsu" }
          - { platform: "Instagram", url: "https://www.instagram.com/rct.bsu/" }
          - { platform: "Telegram",  url: "https://t.me/rct_bsu" }
          - { platform: "Facebook",  url: "https://www.facebook.com/groups/1716620758578504" }
          - { platform: "TikTok",    url: "https://www.tiktok.com/@rfiktss" }

  # ─── КОНТЕНТ ─────────────────────────────────────────────────────────────────

  content:
    format = "MDX с YAML frontmatter"
    directory = "src/content/"
    migration_script = "scripts/migrate-content.js"
    note = "Скрипт читает old_site/content/*.md и конвертирует в .mdx с нужным frontmatter"

    files:
      - { dest: "src/content/home.mdx",                        source: "old_site/content/home.md" }
      - { dest: "src/content/faculty.mdx",                     source: "old_site/content/faculty.md" }
      - { dest: "src/content/faculty_administration.mdx",      source: "old_site/content/faculty_administration.md" }
      - { dest: "src/content/faculty_staff.mdx",               source: "old_site/content/faculty_staff.md" }
      - { dest: "src/content/faculty_council.mdx",             source: "old_site/content/faculty_council.md" }
      - { dest: "src/content/admissions.mdx",                  source: "old_site/content/enrollee.md" }
      - { dest: "src/content/education.mdx",                   source: "old_site/content/education.md" }
      - { dest: "src/content/science.mdx",                     source: "old_site/content/science.md" }
      - { dest: "src/content/science_conferences.mdx",         source: "old_site/content/science.md (раздел конференций)" }
      - { dest: "src/content/contacts.mdx",                    source: "old_site/content/contacts.md" }
    departments:
      pattern = "src/content/departments/{slug}.mdx"
      note = "Каждая кафедра имеет основной файл и 4 дополнительных подраздела (sub_files)."
      MISSING_FILE = "old_site/content/dept_teleit_scientific_directions.md отсутствует — раздел 'Научные направления' для кафедры teleit генерировать из данных SODL или оставить пустым."
      sources:
        - slug = "rdmt"
          source = "old_site/content/dept_rdmt.md"
          sub_files:
            scientific_directions = "old_site/content/dept_rdmt_scientific_directions.md"
            science               = "old_site/content/dept_rdmt_science.md"
            staff                 = "old_site/content/dept_rdmt_staff.md"
            famous_graduates      = "old_site/content/dept_rdmt_famous_graduates.md"
        - slug = "qro"
          source = "old_site/content/dept_qro.md"
          sub_files:
            scientific_directions = "old_site/content/dept_qro_scientific_directions.md"
            science               = "old_site/content/dept_qro_science.md"
            staff                 = "old_site/content/dept_qro_staff.md"
            famous_graduates      = "old_site/content/dept_qro_famous_graduates.md"
        - slug = "physelnano"
          source = "old_site/content/dept_physelnano.md"
          sub_files:
            scientific_directions = "old_site/content/dept_physelnano_scientific_directions.md"
            science               = "old_site/content/dept_physelnano_science.md"
            staff                 = "old_site/content/dept_physelnano_staff.md"
            famous_graduates      = "old_site/content/dept_physelnano_famous_graduates.md"
        - slug = "ics"
          source = "old_site/content/dept_ics.md"
          sub_files:
            scientific_directions = "old_site/content/dept_ics_scientific_directions.md"
            science               = "old_site/content/dept_ics_science.md"
            staff                 = "old_site/content/dept_ics_staff.md"
            famous_graduates      = "old_site/content/dept_ics_famous_graduates.md"
            competencies          = "old_site/content/dept_ics_competencies.md"
        - slug = "kis"
          source = "old_site/content/dept_kis.md"
          sub_files:
            scientific_directions = "old_site/content/dept_kis_scientific_directions.md"
            science               = "old_site/content/dept_kis_science.md"
            staff                 = "old_site/content/dept_kis_staff.md"
            famous_graduates      = "old_site/content/dept_kis_famous_graduates.md"
        - slug = "teleit"
          source = "old_site/content/dept_teleit.md"
          sub_files:
            scientific_directions = null
            scientific_directions_note = "ОТСУТСТВУЕТ: old_site/content/dept_teleit_scientific_directions.md"
            science               = "old_site/content/dept_teleit_science.md"
            staff                 = "old_site/content/dept_teleit_staff.md"
            famous_graduates      = "old_site/content/dept_teleit_famous_graduates.md"
        - slug = "sacm"
          source = "old_site/content/dept_sacm.md"
          sub_files:
            scientific_directions = "old_site/content/dept_sacm_scientific_directions.md"
            science               = "old_site/content/dept_sacm_science.md"
            staff                 = "old_site/content/dept_sacm_staff.md"
            famous_graduates      = "old_site/content/dept_sacm_famous_graduates.md"
        - slug = "phaerotech"
          source = "old_site/content/dept_phaerotech.md"
          sub_files:
            scientific_directions = "old_site/content/dept_phaerotech_scientific_directions.md"
            science               = "old_site/content/dept_phaerotech_science.md"
            staff                 = "old_site/content/dept_phaerotech_staff.md"
            famous_graduates      = "old_site/content/dept_phaerotech_famous_graduates.md"
    programs:
      note = "Файлы специальностей находятся в old_site/content/specialties/. Каждый файл — отдельный трек/направление. old_site/content/specialties.md — обзорная страница, использовать как справочный источник для BachelorIndexPage."
      bachelor:
        # РФИТ — главная специальность + 5 треков
        - { slug: "rphit",  source: "old_site/content/specialties/rphit.md",   tracks_dir: "old_site/content/specialties/",
            track_files: ["aero.md","inform.md","kptms.md","fpkt.md","rdt.md"] }
        # Прикладная информатика — нет отдельного файла ai.md, контент агрегируется из треков
        - { slug: "ai",     source: null,   note: "Нет отдельного ai.md — использовать данные из SODL модуля BachelorProgramDetailPage.static_params.ai",
            track_files: ["old_site/content/specialties/ics.md","old_site/content/specialties/bd.md"] }
        - { slug: "cs",     source: "old_site/content/specialties/cs.md" }
        - { slug: "ie",     source: "old_site/content/specialties/ie.md" }
      master:
        # rfitm.md отсутствует — контент генерируется из данных модуля MasterProgramDetailPage
        - { slug: "rfitm",  source: null,   note: "Файл old_site/content/specialties/rfitm.md отсутствует — использовать данные из SODL модуля" }
        - { slug: "cs-mag", source: "old_site/content/specialties/cs-mag.md" }
        - { slug: "aerocos",source: "old_site/content/specialties/aerocos.md" }
    admissions_sub:
      note = "Страницы поступления по специальностям: old_site/content/enrollee/{slug}.md"
      MIGRATION_WARNING = "Файл old_site/content/enrollee/сs.md содержит кириллическую букву 'с'. Переименовать в cs.md в ходе миграции."
      files:
        - { slug: "rphit",  dest: "src/content/admissions/rphit.mdx",   source: "old_site/content/enrollee/rphit.md" }
        - { slug: "ai",     dest: "src/content/admissions/ai.mdx",       source: "old_site/content/enrollee/ai.md" }
        - { slug: "cs",     dest: "src/content/admissions/cs.mdx",       source: "old_site/content/enrollee/сs.md",  rename_required: true }
        - { slug: "inelec", dest: "src/content/admissions/inelec.mdx",   source: "old_site/content/enrollee/inelec.md" }
        - { slug: "rfitm",  dest: "src/content/admissions/rfitm.mdx",    source: "old_site/content/enrollee/rfitm.md" }
        - { slug: "cs-mag", dest: "src/content/admissions/cs-mag.mdx",   source: "old_site/content/enrollee/cs-mag.md" }
        - { slug: "aerot",  dest: "src/content/admissions/aerot.mdx",    source: "old_site/content/enrollee/aerot.md" }
    science_schools:
      files:
        - { slug: "semiconductor", dest: "src/content/science/school-semiconductor.mdx", source: "old_site/content/science/school-semiconductor.md" }
        - { slug: "informatics",   dest: "src/content/science/school-informatics.mdx",   source: "old_site/content/science/school-informatics.md" }
    news:
      directory = "src/content/news/"
      naming = "{YYYY-MM-DD}-{slug}.mdx"
      source = "old_site/news/ — все статьи"
      frontmatter_schema:
        title: string
        date: "YYYY-MM-DD"
        tags: "('enrollee'|'media'|'students'|'events'|'science')[]"
        excerpt: string
        image: "string (опционально)"
        author: "string (опционально)"

  # ─── КОНФИГУРАЦИЯ ─────────────────────────────────────────────────────────────

  config:
    next_config:
      file = "next.config.js"
      output = "export"
      trailingSlash = true
      images_unoptimized = true
      note = "output:'export' для статического деплоя. images.unoptimized:true если не Vercel."
      redirects:
        - { source: "/enrollee",         destination: "/admissions",           permanent: true }
        - { source: "/enrollee/:path*",  destination: "/admissions/:path*",    permanent: true }
        - { source: "/specialties",      destination: "/programs",             permanent: true }
        - { source: "/specialties/:path*", destination: "/programs/bachelor/:path*", permanent: true }
        - { source: "/cookieCons",       destination: "/",                     permanent: false }
      note_redirects = "Redirects не работают в output:'export'. Реализовать через middleware.ts или nginx/apache rewrite rules на сервере."

    tailwind:
      file = "tailwind.config.ts"
      content = ["./src/**/*.{ts,tsx,mdx}"]
      extend_colors:
        "bg-primary":   "#1C1C1E"
        "bg-section":   "#141416"
        "accent":       "#1A56DB"
        "text-primary": "#FFFFFF"
        "text-secondary":"#8A8A8E"
        "text-muted":   "#6B6B70"
        "border-col":   "#2C2C2E"
      extend_fontFamily:
        "display": ["Archivo Black", "sans-serif"]
        "body":    ["Inter", "sans-serif"]

    tsconfig:
      strict = true
      paths = { "@/*": ["./src/*"] }

    package_json_scripts:
      dev = "next dev"
      build = "next build"
      index-search = "npx pagefind --site out --output-path public/pagefind"
      build:full = "next build && npm run index-search"
      lint = "next lint"
      typecheck = "tsc --noEmit"
      validate-links = "npx broken-link-checker http://localhost:3000 -ro --exclude /docs/"

  # ─── ПОЛИТИКИ ────────────────────────────────────────────────────────────────

  policy LinkIntegrity:
    severity = "error"
    rules:
      - "Каждый href в модулях ОБЯЗАН вести на реальный route или внешний URL"
      - "Нет href='#' в продакшене (только anchor href='#anchor-id')"
      - "Внешние ссылки: target='_blank' rel='noopener noreferrer'"
      - "PDF/DOCX: файлы должны существовать в public/docs/ или быть внешними URL"
      - "Все [slug] роуты ОБЯЗАНЫ иметь generateStaticParams с полным списком значений"
      - "Новостные [slug] роуты генерируются из имён файлов src/content/news/"
      - "Статическая сборка (next build) без 404-ошибок"

  policy DesignSystem:
    severity = "warning"
    rules:
      - "Только цвета из tailwind.config.ts (никаких hardcoded hex в JSX)"
      - "Eyebrow-метки: '// UPPERCASE' Inter 11px, цвет accent, letter-spacing 0.2em"
      - "Все display-заголовки: font-family display (Archivo Black)"
      - "Body-текст: font-family body (Inter)"
      - "Отступ между карточками в сетках: gap-[2px]"
      - "Accent bar: w-10 h-[3px] bg-accent"
      - "Hover на карточках: одна выделенная — bg-accent text-white"

  policy Performance:
    severity = "warning"
    rules:
      - "next/image для всех изображений (WebP, lazy loading)"
      - "Шрифты через @fontsource (self-hosted, нет внешнего CDN)"
      - "Pagefind JS загружается только при открытии SearchOverlay (dynamic import)"
      - "Framer Motion: только CSS-transforms (translateX/Y/scale), нет layout animations на list items"
      - "Цель: Lighthouse ≥ 90 по Performance, Accessibility, Best Practices, SEO"

  policy Accessibility:
    severity = "error"
    rules:
      - "Все <img> и next/Image: осмысленный alt (не пустой для информативных изображений)"
      - "Все интерактивные элементы: keyboard-navigable"
      - "Focus: outline: 2px solid #1A56DB, outline-offset: 2px"
      - "Контраст: WCAG 2.1 AA (4.5:1 для основного текста)"
      - "<html lang='ru'>; английские страницы lang='en'"
      - "Skip-to-content: первый focusable элемент на каждой странице"
      - "Семантика: <main>, <nav>, <header>, <footer>, <article> (новости), <section> с aria-label"

  policy SEO:
    severity = "warning"
    rules:
      - "Каждая страница: уникальные <title> и <meta name='description'>"
      - "Формат title: '{Название страницы} — ФРКТ БГУ'"
      - "Open Graph: og:title, og:description, og:image, og:type на каждой странице"
      - "Canonical URL на каждой странице"
      - "robots.txt и sitemap.xml генерируются при сборке (next-sitemap или встроенный)"
      - "JSON-LD: Organization на главной, BreadcrumbList на всех внутренних страницах"

  policy ContentPreservation:
    severity = "error"
    rules:
      - "Весь текст из old_site/content/ мигрирован в src/content/"
      - "Все PDF из old_site в public/docs/"
      - "Все изображения из old_site/assets/images/ в public/images/"
      - "Логотипы партнёров в public/images/partners/"
      - "Контактные данные (телефоны, email, адрес) — точное соответствие источнику"
      - "Плановый набор 2026 — точные цифры из оригинала"
      - "ФИО и учёные степени заведующих кафедрами — точное соответствие"
      - "Банковские реквизиты конференции QE'2025 — без изменений"

  # ─── ПАЙПЛАЙН СБОРКИ ─────────────────────────────────────────────────────────

  pipeline Build:
    steps:
      - step = "install"
        cmd = "pnpm install"

      - step = "copy-assets"
        cmd = "node scripts/copy-assets.js"
        note = "Копирует old_site/assets/images/ → public/images/, old_site PDF → public/docs/"

      - step = "migrate-content"
        cmd = "node scripts/migrate-content.js"
        note = "Конвертирует old_site/content/*.md → src/content/*.mdx с frontmatter"

      - step = "build"
        cmd = "pnpm build"
        output = "out/ (статические HTML-файлы)"

      - step = "index-search"
        cmd = "npx pagefind --site out --output-path public/pagefind"
        note = "ОБЯЗАТЕЛЬНО после build. Создаёт индекс Pagefind для поиска."

      - step = "validate-links"
        cmd = "npx serve out -p 3000 & sleep 3 && npx broken-link-checker http://localhost:3000 -ro"
        note = "Проверяет все внутренние ссылки. Нет 404-ошибок — обязательное условие."

      - step = "lint"
        cmd = "pnpm lint && pnpm typecheck"

  pipeline Dev:
    steps:
      - step = "dev"
        cmd = "pnpm dev"
        note = "Pagefind недоступен в dev-режиме (требует build). Для теста поиска — build:full."

  # ─── ЗАМЕТКИ ПО МИГРАЦИИ ─────────────────────────────────────────────────────

  migration_notes:

    missing_files:
      - path = "old_site/content/dept_teleit_scientific_directions.md"
        status = "ОТСУТСТВУЕТ"
        action = "Показать заглушку на странице /faculty/departments/teleit в разделе 'Научные направления'"

      - path = "old_site/content/specialties/rfitm.md"
        status = "ОТСУТСТВУЕТ"
        action = "Содержимое страницы /programs/master/rfitm генерировать из данных модуля MasterProgramDetailPage.static_params.rfitm"

      - path = "old_site/content/specialties/ai.md"
        status = "ОТСУТСТВУЕТ"
        action = "Содержимое страницы /programs/bachelor/ai генерировать из данных модуля BachelorProgramDetailPage.static_params.ai + треки ics.md, bd.md"

      - path = "public/images/dean_ushakov.jpg"
        status = "ОТСУТСТВУЕТ локально"
        action = "Скачать с https://rct.bsu.by/ или использовать placeholder. Используется на страницах /faculty/administration и /admissions."

      - path = "public/images/map_faculty.jpg"
        status = "ОТСУТСТВУЕТ локально"
        action = "Создать статичный скриншот из Яндекс.Карты или использовать iframe. Резервный для /contacts."

      - path = "public/docs/*.pdf"
        status = "PDF-файлы отсутствуют в old_site"
        action = "Все PDF необходимо скачать с https://rct.bsu.by/ вручную и поместить в public/docs/ согласно разделу assets.documents. Документы для скачивания: admission_rules_2026.pdf, bsu_admission_procedure_2025.pdf, rcft_admission_features_2025.pdf, preferential_categories.pdf, diploma_template.docx, и прочие учебные программы (syllabi/)."

    filename_issues:
      - path = "old_site/content/enrollee/сs.md"
        issue = "Кириллическая буква 'с' (U+0441) в имени файла вместо латинской 'c' (U+0063)"
        action = "В scripts/migrate-content.js: при копировании этого файла использовать целевое имя 'cs.md' (латиница)"
        migrate_code = "if (filename === 'сs.md') destName = 'cs.md'"

    news_count:
      actual = 21
      note_in_sodl = "В SODL упоминается 35 страниц новостей — это страницы пагинации оригинального сайта, а не статьи. Реальных статей в old_site/content/news/ = 21."

    news_slug_normalization:
      problem = "Имена файлов новостей не всегда пригодны для URL. Скрипт миграции ОБЯЗАН нормализовать slug."
      rules:
        - "Привести к нижнему регистру"
        - "Заменить пробелы и подчёркивания на дефисы"
        - "Удалить апострофы и специальные символы (пример: 'People's_Guest' → 'peoples-guest')"
        - "Сохранить дату-префикс: YYYY-MM-DD-slug"
      examples:
        - from = "2025-04-16-People's_Guest.md"
          to   = "2025-04-16-peoples-guest.mdx"
        - from = "2025-11-16-RCAP_2025.md"
          to   = "2025-11-16-rcap-2025.mdx"
        - from = "2026-03-10-Pozdnyakov_dv.md"
          to   = "2026-03-10-pozdnyakov-dv.mdx"
      note = "generateStaticParams для /news/[slug] должен читать имена файлов src/content/news/*.mdx после нормализации."

    science_split:
      problem = "old_site/content/science.md содержит весь научный контент — нужно разбить на два MDX-файла."
      split_logic:
        science_mdx:
          dest = "src/content/science.mdx"
          content = "Весь текст кроме подробных данных о конференциях: общие направления, лаборатории (краткий список), научные школы (краткий список)."
        science_conferences_mdx:
          dest = "src/content/science_conferences.mdx"
          content = "Детальные данные о конференциях: QE'2025, CTDA, Applied Optics — всё что относится к конференциям."
        note = "Если в science.md нет явных секций — весь текст дублировать в оба файла; ConferencesPage отобразит inline-данные из SODL модуля ConferencesPage."

    image_paths_note:
      rule = "В JSX-компонентах (next/image src, <img> src): использовать /images/... (URL относительно public/ root)."
      rule2 = "В скриптах миграции и SODL content.assets: использовать public/images/... (файловые пути)."
      note = "next/image НЕ принимает пути типа 'public/images/foo.jpg' — только '/images/foo.jpg'."

    redirects_implementation:
      problem = "redirects() в next.config.js НЕ работают с output:'export' (статическая сборка)."
      solution_option_a = "middleware.ts в корне src/: перехватывает запросы и делает Next.js redirect. Работает на Vercel и серверах с Node.js."
      solution_option_b = "nginx/apache rewrite rules на сервере (для VPS/shared hosting)."
      solution_option_c = "Статические 404.html с JS-редиректом (fallback, не SEO-friendly)."
      recommendation = "Для деплоя на static hosting: создать src/middleware.ts с маппингом старых URL → новых. Это работает в Next.js App Router даже при output:'export' на Vercel."
      middleware_pattern = "export function middleware(req) { const oldPaths = {'/enrollee': '/admissions', ...}; const redirect = oldPaths[req.nextUrl.pathname]; if (redirect) return NextResponse.redirect(new URL(redirect, req.url)); }"

      - id = "about-teaser"
        component = "AboutTeaser"
        file = "src/components/sections/AboutTeaser.tsx"
        bg = "#141416"
        eyebrow = "// О ФАКУЛЬТЕТЕ"
        headline = "Единственный физико-технический\nфакультет в Беларуси"
        body = "Готовим специалистов мирового уровня. Уникальное сочетание: информатика, программирование, радиофизика, электроника. С нами работали над проектами Марс, Венера, Буран-Энергия и первым белорусским наноспутником БГУСат-1."
        achievements:
          - "Антенны для межпланетных космических станций"
          - "БГУСат-1 — первый наноспутник белорусского университета"
          - "Проекты Марс, Венера, Буран-Энергия"
          - "Партнёрство с ПВТ, EPAM, ITransition и ведущими IT-компаниями"
        cta = { label: "ОБ УНИВЕРСИТЕТЕ →", href: "/faculty" }

      - id = "news-preview"
        component = "NewsPreview"
        file = "src/components/sections/NewsPreview.tsx"
        eyebrow = "// АКТУАЛЬНОЕ"
        heading = "Новости и события"
        cta = { label: "ВСЕ НОВОСТИ →", href: "/news" }
        layout = "2 колонки: большая featured-карточка слева + 3 малые справа"
        items_count = 4
        source = "src/content/news/*.mdx — 4 последних по дате"

      - id = "partners"
        component = "PartnersSection"
        file = "src/components/sections/PartnersSection.tsx"
        bg = "#141416"
        eyebrow = "// ПАРТНЁРЫ"
        heading = "Компании-партнёры"
        layout = "горизонтальный ряд логотипов, grayscale → color on hover"
        items = "из assets.partner_logos"

  # ─── ФАКУЛЬТЕТ ───────────────────────────────────────────────────────────────

  module FacultyPage:
    route = "/faculty"
    file = "src/app/faculty/page.tsx"
    content_file = "src/content/faculty.mdx"
    title = "О факультете — ФРКТ БГУ"
    meta_description = "Единственный физико-технический факультет в Беларуси. Кафедры, история, научные достижения, структура."
    source_url = "https://rct.bsu.by/faculty"

    sections:
      - id = "hero"
        image = "/images/faculty_building.jpg"
        alt = "Корпус ФРКТ БГУ, ул. Академика Курчатова, 5"
        overlay_headline = "// ФАКУЛЬТЕТ РАДИОФИЗИКИ И КОМПЬЮТЕРНЫХ ТЕХНОЛОГИЙ"

      - id = "stats"
        component = "StatsBand"
        items:
          - { value: "100+", label: "ПРЕПОДАВАТЕЛЕЙ" }
          - { value: "1",    label: "АКАДЕМИК НАН" }
          - { value: "12",   label: "ДОКТОРОВ НАУК" }
          - { value: "32",   label: "ДОЦЕНТОВ" }
          - { value: "32",   label: "ИНЖЕНЕРОВ" }

      - id = "overview"
        eyebrow = "// О НАС"
        heading = "Уникальная комбинация знаний"
        content_from = "src/content/faculty.mdx#overview"
        key_points:
          - "Единственный физико-технический факультет в Республике Беларусь"
          - "Готовит физиков-инженеров для радиоэлектроники, электроники, телекоммуникаций и ИТ"
          - "Уникальное сочетание: информатика, программирование, радиофизика, электроника"
          - "Международные научно-технические связи"

      - id = "history"
        anchor = "history"
        eyebrow = "// ИСТОРИЯ"
        heading = "Достижения"
        timeline:
          - { era: "XX век",  text: "Антенны для межпланетных космических станций" }
          - { era: "2021",    text: "БГУСат-1 — первый наноспутник белорусского университета" }
          - { era: "2022",    text: "БГУСат-2 — второй малый космический аппарат" }
          - { era: "Прошлое", text: "Проекты Марс, Венера, Буран-Энергия; оборонная и авиационная промышленность" }

      - id = "research-directions"
        eyebrow = "// ИССЛЕДОВАНИЯ"
        heading = "Направления научной работы"
        items:
          - "Современная информатика и обработка изображений"
          - "IoT и искусственный интеллект"
          - "Нейронные сети и кибербезопасность"
          - "Системный анализ и интеллектуальные системы"
          - "Распознавание речи и компьютерные сети"
          - "Наноэлектроника и квантовые вычисления"
          - "Смарт-электроника и аэрокосмические технологии"
          - "Медико-биологические исследования и биоинформатика"

      - id = "departments-grid"
        eyebrow = "// КАФЕДРЫ"
        heading = "8 кафедр"
        cta = { label: "ВСЕ КАФЕДРЫ →", href: "/faculty/departments" }
        layout = "2×4 сетка карточек"
        items:
          - { slug: "rdmt",       name: "Радиофизики и цифровых медиа технологий",                      href: "/faculty/departments/rdmt" }
          - { slug: "qro",        name: "Квантовой радиофизики и оптоэлектроники",                      href: "/faculty/departments/qro" }
          - { slug: "physelnano", name: "Физической электроники и нанотехнологий",                      href: "/faculty/departments/physelnano" }
          - { slug: "ics",        name: "Информатики и компьютерных систем",                            href: "/faculty/departments/ics" }
          - { slug: "kis",        name: "Интеллектуальных систем",                                      href: "/faculty/departments/kis" }
          - { slug: "teleit",     name: "Телекоммуникаций и информационных технологий",                 href: "/faculty/departments/teleit" }
          - { slug: "sacm",       name: "Системного анализа и компьютерного моделирования",             href: "/faculty/departments/sacm" }
          - { slug: "phaerotech", name: "Физики и аэрокосмических технологий",                          href: "/faculty/departments/phaerotech" }

      - id = "links"
        heading = "Документы и ресурсы"
        items:
          - { label: "Сотрудники",          href: "/faculty/staff" }
          - { label: "Руководство",          href: "/faculty/administration" }
          - { label: "Учёный совет",         href: "/faculty/council" }
          - { label: "Каталог дисциплин",    href: "/faculty#catalog" }
          - { label: "Распределение 2025",   href: "/faculty#distribution" }


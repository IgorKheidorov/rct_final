system "RCFT_BSU_V2":
  version = "2.0.0"
  description = "Рефакторинг сайта ФРКТ БГУ. Next.js 14 SSG, Концепция E (Geometric Modernist), полное сохранение контента, контекстный поиск Pagefind."
  source_reference = "https://rct.bsu.by/"
  paper_design_artboard = "FM-0"

  stack:
    language = "TypeScript"
    framework = "Next.js 14 (App Router, output: export)"
    styling = "Tailwind CSS v3"
    content = "MDX (next-mdx-remote — использовать import из 'next-mdx-remote/rsc' для App Router RSC)"
    search = "Pagefind (static full-text, indexed at build time)"
    animations = "Framer Motion (subtle, performance-safe)"
    icons = "Lucide React"
    fonts = ["Archivo Black (@fontsource/archivo-black)", "Inter (@fontsource/inter)"]
    node_version = ">=20"
    package_manager = "pnpm"

  implementation_notes:
    mdx_import = "ОБЯЗАТЕЛЬНО: import { MDXRemote } from 'next-mdx-remote/rsc' (НЕ из 'next-mdx-remote'). App Router RSC требует /rsc субпакет."
    image_src   = "ОБЯЗАТЕЛЬНО: в JSX src для изображений — '/images/foo.jpg', НЕ 'public/images/foo.jpg'. next/image не принимает пути с 'public/'."
    static_params = "ОБЯЗАТЕЛЬНО: каждый [slug] и [track] маршрут должен экспортировать generateStaticParams(). Без этого next build с output:'export' упадёт."
    redirects   = "ВАЖНО: redirects() в next.config.js не работают с output:'export'. Реализовать через src/middleware.ts (см. migration_notes.redirects_implementation)."
    tailwind_v3 = "Tailwind CSS v3. НЕ v4. Конфиг: tailwind.config.ts с content: ['./src/**/*.{ts,tsx,mdx}']."
    pagefind    = "Pagefind индексируется ПОСЛЕ next build: npx pagefind --site out --output-path public/pagefind. В dev-режиме поиск не работает."
    fonts       = "Шрифты через @fontsource: 'import @fontsource/archivo-black' и 'import @fontsource/inter' в globals.css. НЕ Google Fonts CDN."

  intent:
    primary = "Полный редизайн сайта ФРКТ БГУ: современный стек, дизайн Концепция E, 100% контента, контекстный поиск"
    outcomes:
      - "Весь оригинальный контент (тексты, PDF, изображения) сохранён и доступен"
      - "Дизайн Концепция E: #1C1C1E графит, #1A56DB электрик, Archivo Black + Inter"
      - "Полнотекстовый контекстный поиск Pagefind по всему сайту"
      - "Все внутренние ссылки валидированы и работают"
      - "Редиректы со старых URL (enrollee→admissions, specialties→programs)"
      - "Mobile-first, адаптивный (breakpoints: 640/768/1024/1280px)"
      - "Lighthouse ≥ 90 по всем метрикам"
      - "SEO: title, meta description, OG, JSON-LD, sitemap.xml, robots.txt"
      - "Статическая сборка (next export) — деплой на любой веб-сервер"

  # ─── ДИЗАЙН-СИСТЕМА ────────────────────────────────────────────────────────

  design_system:
    name = "Concept E — Geometric Modernist"
    reference_artboard = "FM-0 в Paper"

    colors:
      bg_primary = "#1C1C1E"
      bg_section = "#141416"
      bg_card = "#1C1C1E"
      accent = "#1A56DB"
      text_primary = "#FFFFFF"
      text_secondary = "#8A8A8E"
      text_muted = "#6B6B70"
      border = "#2C2C2E"
      divider = "#2C2C2E"

    typography:
      display_font = "Archivo Black"
      body_font = "Inter"
      display_sizes = "48–80px, line-height 0.95–1.05, letter-spacing -0.02em"
      h2_size = "36px"
      h3_size = "24px"
      body_size = "16px, line-height 1.75"
      caption_size = "13px"
      label_size = "11px, uppercase, letter-spacing 0.2em"

    patterns:
      section_label = "// UPPERCASE TEXT — Inter 11px, #1A56DB, letter-spacing 0.2em"
      accent_bar = "width:40px height:3px bg:#1A56DB — декоративный разделитель"
      card_gap = "2px между карточками (не margin)"
      section_padding = "80px вертикальный, 80px горизонтальный"
      hover_highlight = "одна карточка в сетке bg:#1A56DB для акцента"
      external_link_icon = "↗ или иконка Lucide ExternalLink"

    tokens_file = "tailwind.config.ts"
    tokens:
      colors:
        "bg-primary": "#1C1C1E"
        "bg-section": "#141416"
        "accent": "#1A56DB"
        "text-primary": "#FFFFFF"
        "text-secondary": "#8A8A8E"
        "text-muted": "#6B6B70"
        "border-default": "#2C2C2E"
      fontFamily:
        "display": ["Archivo Black", "sans-serif"]
        "body": ["Inter", "sans-serif"]

  # ─── АРХИТЕКТУРА ────────────────────────────────────────────────────────────

  architecture:
    pattern = "JAMstack — Next.js App Router SSG"

    directory:
      "src/app/"                    = "Next.js App Router — страницы и layouts"
      "src/components/"             = "Переиспользуемые React-компоненты"
      "src/components/layout/"      = "Header, Footer, Layout wrapper"
      "src/components/sections/"    = "Section-компоненты страниц"
      "src/components/ui/"          = "Атомарные компоненты (Button, Card, Tag)"
      "src/components/search/"      = "SearchBar, SearchOverlay, SearchResultsPage"
      "src/content/"                = "MDX-файлы контента"
      "src/content/news/"           = "MDX-статьи новостей"
      "src/content/departments/"    = "MDX по кафедрам (основные файлы + sub-файлы вида {slug}-staff.mdx)"
      "src/content/programs/"       = "MDX по специальностям"
      "src/content/programs/bachelor/" = "MDX по специальностям бакалавриата + трек-страницы"
      "src/content/programs/master/"   = "MDX по специальностям магистратуры"
      "src/content/admissions/"     = "MDX по поступлению на каждую специальность"
      "src/content/science/"        = "MDX научных школ"
      "src/lib/"                    = "Утилиты, хелперы, типы"
      "src/styles/"                 = "globals.css, Tailwind директивы"
      "public/"                     = "Статические файлы"
      "public/images/"              = "Все изображения (скопировать из old_site)"
      "public/images/partners/"     = "Логотипы партнёров"
      "public/docs/"                = "PDF-документы"
      "public/pagefind/"            = "Pagefind-индекс (генерируется при сборке)"
      "scripts/"                    = "migrate-content.js, validate-links.js"

    routes:
      - path = "/"
        file = "src/app/page.tsx"
      - path = "/faculty"
        file = "src/app/faculty/page.tsx"
      - path = "/faculty/departments"
        file = "src/app/faculty/departments/page.tsx"
      - path = "/faculty/departments/[slug]"
        file = "src/app/faculty/departments/[slug]/page.tsx"
        params = ["rdmt","qro","physelnano","ics","kis","teleit","sacm","phaerotech"]
      - path = "/faculty/staff"
        file = "src/app/faculty/staff/page.tsx"
      - path = "/faculty/administration"
        file = "src/app/faculty/administration/page.tsx"
      - path = "/faculty/council"
        file = "src/app/faculty/council/page.tsx"
      - path = "/programs"
        file = "src/app/programs/page.tsx"
      - path = "/programs/bachelor"
        file = "src/app/programs/bachelor/page.tsx"
      - path = "/programs/bachelor/[slug]"
        file = "src/app/programs/bachelor/[slug]/page.tsx"
        params = ["rphit","ai","cs","ie"]
      - path = "/programs/bachelor/[slug]/[track]"
        file = "src/app/programs/bachelor/[slug]/[track]/page.tsx"
        note = "Единый вложенный маршрут для всех треков. Next.js App Router: [slug]/page.tsx и [slug]/[track]/page.tsx сосуществуют."
        params:
          rphit: ["aero","inform","kptms","fpkt","rdt"]
          ai:    ["ics","bd"]
          cs:    ["cs"]
          ie:    ["ie"]
      - path = "/programs/master"
        file = "src/app/programs/master/page.tsx"
      - path = "/programs/master/[slug]"
        file = "src/app/programs/master/[slug]/page.tsx"
        params = ["rfitm","cs-mag","aerocos"]
      - path = "/admissions"
        file = "src/app/admissions/page.tsx"
      - path = "/admissions/[specialty]"
        file = "src/app/admissions/[specialty]/page.tsx"
        params = ["rphit","ai","cs","inelec","rfitm","cs-mag","aerot"]
      - path = "/education"
        file = "src/app/education/page.tsx"
      - path = "/science"
        file = "src/app/science/page.tsx"
      - path = "/science/conferences"
        file = "src/app/science/conferences/page.tsx"
      - path = "/science/labs"
        file = "src/app/science/labs/page.tsx"
      - path = "/science/schools/[slug]"
        file = "src/app/science/schools/[slug]/page.tsx"
        params = ["semiconductor","informatics"]
      - path = "/news"
        file = "src/app/news/page.tsx"
      - path = "/news/[slug]"
        file = "src/app/news/[slug]/page.tsx"
        params = "dynamic from src/content/news/*.mdx filenames"
      - path = "/contacts"
        file = "src/app/contacts/page.tsx"
      - path = "/search"
        file = "src/app/search/page.tsx"

    redirects:
      file = "next.config.js → redirects()"
      rules:
        - from = "/enrollee"
          to = "/admissions"
          permanent = true
        - from = "/enrollee/:path*"
          to = "/admissions/:path*"
          permanent = true
        - from = "/specialties"
          to = "/programs"
          permanent = true
        - from = "/specialties/:path*"
          to = "/programs/bachelor/:path*"
          permanent = true
        - from = "/cookieCons"
          to = "/"
          permanent = false

  # ─── АССЕТЫ ─────────────────────────────────────────────────────────────────

  assets:
    images:
      source = "old_site/assets/images/"
      dest = "public/images/"
      note = "Копировать все файлы. next/image обеспечит оптимизацию WebP + lazy load."
      files:
        - src = "old_site/assets/images/logo.svg"
          dest = "public/images/logo.svg"
        - src = "old_site/assets/images/faculty_building.jpg"
          dest = "public/images/faculty_building.jpg"
        - src = "old_site/assets/images/banner_open_house_march28.jpg"
          dest = "public/images/banner_open_house_march28.jpg"
        - src = "old_site/assets/images/banner_robocup_asia_pacific_2025.jpg"
          dest = "public/images/banner_robocup_asia_pacific_2025.jpg"
        - src = "old_site/assets/images/specialty_aerospace.jpg"
          dest = "public/images/specialty_aerospace.jpg"
        - src = "old_site/assets/images/specialty_informatics.jpg"
          dest = "public/images/specialty_informatics.jpg"
        - src = "old_site/assets/images/specialty_microelectronics.jpg"
          dest = "public/images/specialty_microelectronics.jpg"
        - src = "old_site/assets/images/specialty_photonics.jpg"
          dest = "public/images/specialty_photonics.jpg"
        - src = "old_site/assets/images/specialty_digital_tech.jpg"
          dest = "public/images/specialty_digital_tech.jpg"
        - src = "old_site/assets/images/specialty_intelligent_systems.jpg"
          dest = "public/images/specialty_intelligent_systems.jpg"
        - src = "old_site/assets/images/specialty_bioinformatics.jpg"
          dest = "public/images/specialty_bioinformatics.jpg"
        - src = "old_site/assets/images/specialty_cybersecurity.jpg"
          dest = "public/images/specialty_cybersecurity.jpg"
        - src = "old_site/assets/images/specialty_intelligent_electronics.jpg"
          dest = "public/images/specialty_intelligent_electronics.jpg"
        - src = "old_site/assets/images/masters_program_1.jpg"
          dest = "public/images/masters_program_1.jpg"
        - src = "old_site/assets/images/masters_program_2.jpg"
          dest = "public/images/masters_program_2.jpg"
        - src = "old_site/assets/images/masters_aerospace.jpg"
          dest = "public/images/masters_aerospace.jpg"

    partner_logos:
      source = "old_site/assets/images/partners/"
      dest = "public/images/partners/"
      files:
        - { name: "LeverX",         file: "leverx.png",        url: "https://leverx.com" }
        - { name: "EPAM",            file: "epam.png",          url: "https://epam.com" }
        - { name: "ITransition",     file: "itransition.png",   url: "https://itransition.com" }
        - { name: "NTLab",           file: "ntlab.png",         url: "https://ntlab.com" }
        - { name: "Aristek Systems", file: "aristek.svg",       url: "https://aristeksystems.com" }
        - { name: "Abiatec",         file: "abiatec.svg",       url: "https://abiatec.com" }
        - { name: "Effective Soft",  file: "effective_soft.png",url: "https://effectivesoft.com" }
        - { name: "D-Link",          file: "d-link.png",        url: "https://dlink.ru" }
        - { name: "ПВТ (HTP)",       file: "htp.jpg",           url: "https://park.by" }

    documents:
      source = "old_site/ (любые PDF и DOCX)"
      dest = "public/docs/"
      required:
        - "admission_rules_2026.pdf"
        - "bsu_admission_procedure_2025.pdf"
        - "rcft_admission_features_2025.pdf"
        - "preferential_categories.pdf"
        - "diploma_template.docx"
        - "coursework_title.docx"
        - "diploma_title.docx"
        - "coursework_assignment.docx"
        - "diploma_assignment.docx"
        - "syllabi/bachelor_*.pdf (все учебные программы)"
        - "syllabi/master_*.pdf"

  # ─── LAYOUT ──────────────────────────────────────────────────────────────────

  module Layout:
    file = "src/app/layout.tsx"
    owns = ["<html>", "<head>", "Header", "Footer", "SearchOverlay"]

    head:
      charset = "UTF-8"
      viewport = "width=device-width, initial-scale=1.0"
      theme_color = "#1C1C1E"
      analytics:
        - type = "Google Analytics"
          id = "G-LXPCYWCCZV"
          impl = "gtag.js через next/script strategy='afterInteractive'"
        - type = "Yandex Metrica"
          id = "88540556"
          impl = "next/script strategy='afterInteractive'"

    header:
      file = "src/components/layout/Header.tsx"
      bg = "#1C1C1E"
      height = "72px"
      border_bottom = "1px solid #2C2C2E"
      logo:
        src = "/images/logo.svg"
        alt = "ФРКТ БГУ — Факультет радиофизики и компьютерных технологий"
        href = "/"
        accent_bar = "8px × 32px bg:#1A56DB mr-3"
        text = "ФРКТ"
        subtext = "БГУ"
      nav:
        - { label: "Факультет",      href: "/faculty" }
        - { label: "Программы",      href: "/programs" }
        - { label: "Абитуриентам",   href: "/admissions" }
        - { label: "Обучение",       href: "/education" }
        - { label: "Наука",          href: "/science" }
        - { label: "Новости",        href: "/news" }
        - { label: "Контакты",       href: "/contacts" }
      search_button:
        icon = "Lucide Search"
        label = "Поиск (Ctrl+K)"
        action = "открывает SearchOverlay"
        keyboard_shortcut = "Ctrl+K / Cmd+K"
      cta:
        label = "ПОСТУПИТЬ →"
        href = "/admissions"
        style = "bg:#1A56DB font:Archivo-Black 13px uppercase tracking-wide px-6 py-2"
      mobile:
        breakpoint = "< 1024px"
        shows = "бургер-меню, все ссылки в drawer"

    footer:
      file = "src/components/layout/Footer.tsx"
      bg = "#111827"
      columns:
        - heading = "ФРКТ БГУ"
          links:
            - { label: "О факультете",   href: "/faculty" }
            - { label: "История",         href: "/faculty#history" }
            - { label: "Руководство",     href: "/faculty/administration" }
            - { label: "Кафедры",         href: "/faculty/departments" }
            - { label: "Учёный совет",    href: "/faculty/council" }
        - heading = "ОБУЧЕНИЕ"
          links:
            - { label: "Бакалавриат",       href: "/programs/bachelor" }
            - { label: "Магистратура",      href: "/programs/master" }
            - { label: "Расписание",        href: "/education#schedules" }
            - { label: "Учебный календарь", href: "/education#calendar" }
            - { label: "Документы",         href: "/education#documents" }
        - heading = "АБИТУРИЕНТАМ"
          links:
            - { label: "Как поступить",             href: "/admissions" }
            - { label: "Специальности",             href: "/programs" }
            - { label: "Плановый набор 2026",       href: "/admissions#places" }
            - { label: "Вступительные испытания",   href: "/admissions#exams" }
            - { label: "Общежитие",                 href: "/admissions#dormitory" }
            - { label: "Дни открытых дверей",       href: "/admissions#open-days" }
        - heading = "КОНТАКТЫ"
          links:
            - { label: "220045, Минск, ул. Академика Курчатова, 5", href: "/contacts" }
            - { label: "+375 (17) 209-58-18",  href: "tel:+375172095818" }
            - { label: "rct@bsu.by",            href: "mailto:rct@bsu.by" }
      social_links:
        - { platform: "VK",        url: "https://vk.com/rfikt_bsu" }
        - { platform: "Telegram",  url: "https://t.me/rct_bsu" }
        - { platform: "Instagram", url: "https://www.instagram.com/rct.bsu/" }
        - { platform: "Facebook",  url: "https://www.facebook.com/groups/1716620758578504" }
        - { platform: "TikTok",    url: "https://www.tiktok.com/@rfiktss" }
      copyright = "© 2025 ФРКТ БГУ. Все права защищены."
      bsu_link:
        label = "Белорусский государственный университет"
        href = "https://bsu.by"

  # ─── ПОИСК ───────────────────────────────────────────────────────────────────

  module Search:
    engine = "Pagefind"
    version = "^1.1"
    index_command = "npx pagefind --site out --output-path public/pagefind"
    note = "Запускать ПОСЛЕ next build. Индексирует все HTML-файлы в /out."

    html_attributes:
      data-pagefind-body = "на <main> каждой страницы — индексируемый контент"
      data-pagefind-meta = "title, description — на <title> и <meta name=description>"
      data-pagefind-ignore = "на <header>, <footer>, <nav> — исключить из индекса"

    components:
      SearchBar:
        file = "src/components/search/SearchBar.tsx"
        placeholder = "Поиск по сайту... (Ctrl+K)"
        style = "border:1px solid #2C2C2E bg:#141416 text:#FFFFFF rounded-none h-10 pl-10"
        icon = "Lucide Search, left, #8A8A8E"
        on_focus = "открывает SearchOverlay"

      SearchOverlay:
        file = "src/components/search/SearchOverlay.tsx"
        trigger = "Ctrl+K / Cmd+K, или клик на SearchBar"
        style = "fixed inset-0 bg-black/80 z-50, centered modal 640px max-w"
        keyboard = "Escape — закрыть; ↑↓ — навигация по результатам; Enter — перейти"
        result_item:
          shows = ["title", "breadcrumb URL", "highlighted excerpt (Pagefind <mark>)"]
          on_click = "navigate + close overlay"
        states:
          empty = "«Начните вводить запрос...»"
          loading = "spinner"
          no_results = "«Ничего не найдено по запросу &laquo;{query}&raquo;»"
          results = "список ResultItem компонентов"

      SearchResultsPage:
        route = "/search"
        file = "src/app/search/page.tsx"
        query_param = "q"
        behavior = "читает ?q=, выполняет pagefind.search(), отображает результаты"
        sections = ["Заголовок: Результаты поиска: {q}", "счётчик результатов", "список ResultItem"]

  # ─── ГЛАВНАЯ СТРАНИЦА ─────────────────────────────────────────────────────────

  module HomePage:
    route = "/"
    file = "src/app/page.tsx"
    title = "Факультет радиофизики и компьютерных технологий — БГУ"
    meta_description = "Единственный физико-технический факультет в Беларуси. Программирование, кибербезопасность, ИИ, радиофизика, аэрокосмические технологии."
    content_file = "src/content/home.mdx"

    sections:
      - id = "hero"
        component = "HeroSection"
        file = "src/components/sections/HeroSection.tsx"
        eyebrow = "// ФАКУЛЬТЕТ РАДИОФИЗИКИ И КОМПЬЮТЕРНЫХ ТЕХНОЛОГИЙ · БГУ"
        headline = "НАУКА.\nЗНАНИЕ.\nБУДУЩЕЕ."
        headline_note = "слово «ЗНАНИЕ.» — цвет #1A56DB"
        subtext = "Единственный физико-технический факультет в Беларуси. Готовим инженеров, программистов, специалистов по ИИ, кибербезопасности и аэрокосмическим технологиям."
        cta_primary:
          label = "ПОСТУПИТЬ →"
          href = "/admissions"
        cta_secondary:
          label = "Программы обучения"
          href = "/programs"
        stats:
          - { value: "100+",  label: "ПРЕПОДАВАТЕЛЕЙ" }
          - { value: "136",   label: "ЛЕТ ИСТОРИИ" }
          - { value: "94%",   label: "ТРУДОУСТРОЙСТВО" }
          - { value: "#1",    label: "В БЕЛАРУСИ" }
        stats_layout = "горизонтальная полоса, разделители 1px #2C2C2E"

      - id = "announcements"
        component = "AnnouncementsBanner"
        file = "src/components/sections/AnnouncementsBanner.tsx"
        bg = "#141416"
        border_top = "1px solid #2C2C2E"
        items:
          - text = "День открытых дверей — 28 марта 2026, 11:00, ул. Курчатова 5, ауд. 115"
            href = "/admissions#open-days"
          - text = "Единый день открытых дверей БГУ — 21 марта, пр. Независимости, 116"
            href = "/admissions#open-days"
          - text = "RoboCup Asia-Pacific 2025 — студенты ФРКТ заняли 1 место"
            href = "/news"

      - id = "programs-overview"
        component = "ProgramsGrid"
        file = "src/components/sections/ProgramsGrid.tsx"
        eyebrow = "// ПРОГРАММЫ"
        heading = "Направления подготовки"
        cta = { label: "ВСЕ ПРОГРАММЫ →", href: "/programs" }
        items:

  module AdmissionsPage:
    route = "/admissions"
    file = "src/app/admissions/page.tsx"
    content_file = "src/content/admissions.mdx"
    title = "Абитуриентам — ФРКТ БГУ"
    meta_description = "Поступление в ФРКТ БГУ 2026. Правила приёма, плановый набор, вступительные испытания, общежитие, дни открытых дверей."
    source_url = "https://rct.bsu.by/enrollee"

    sections:
      - id = "dean-welcome"
        dean_name = "Ушаков Дмитрий Владимирович"
        dean_title = "Декан, д-р физ.-мат. наук, доцент"
        photo = "/images/dean_ushakov.jpg"
        quote = "Факультет радиофизики и компьютерных технологий — единственный физико-технический факультет в Республике Беларусь, готовящий физиков-инженеров для радиоэлектроники, электроники, телекоммуникаций и ИТ. Ждём вас в числе наших студентов."

      - id = "enrollment-stats"
        anchor = "places"
        eyebrow = "// ПЛАНОВЫЙ НАБОР 2026"
        heading = "Бюджетные и платные места"
        bachelor_table:
          headers = ["Специальность", "Код", "Бюджет", "Платно"]
          rows:
            - { specialty: "Радиофизика и информационные технологии", code: "6-05-0533-05", budget: 86, paid: 10 }
            - { specialty: "Прикладная информатика",                   code: "6-05-0533-11", budget: 42, paid: 10 }
            - { specialty: "Кибербезопасность",                        code: "6-05-0533-12", budget: 42, paid: 10 }
            - { specialty: "Интеллектуальная электроника",             code: "6-05-0533-15", budget: 22, paid: 2  }
        master_table:
          rows:
            - { specialty: "Радиофизика и информационные технологии", code: "7-06-0533-03", budget: 10, paid: 3 }
            - { specialty: "Кибербезопасность",                        code: "7-06-0533-08", budget: 13, paid: 1 }
            - { specialty: "Аэрокосмические технологии",               code: "7-06-0533-09", budget: 5,  paid: 1 }

      - id = "requirements"
        anchor = "requirements"
        eyebrow = "// ВСТУПИТЕЛЬНЫЕ ИСПЫТАНИЯ"
        heading = "Требования для поступления"
        content = "4 показателя: 2 централизованных экзамена (русский или белорусский + математика или физика), 1 дополнительный ЦЭ (физика или математика), средний балл аттестата"

      - id = "targeted-admission"
        anchor = "targeted"
        eyebrow = "// ЦЕЛЕВОЙ ПРИЁМ"
        heading = "Целевое направление"
        submission_period = "27 июня — 2 июля 2025"
        location = "Юридический факультет, ауд. 308, ул. Ленина, 8, Минск"
        hours = "9:00–18:00 (выходные: 29 июня, 3 июля)"
        exam_physics_date = "8–9 июля 2024, 9:00"
        consultation = "7 июля 2025"
        downloads:
          - { title: "20 вопросов для вступительного испытания (PDF)", file: "public/docs/targeted_exam_questions.pdf" }
          - { title: "Перечень необходимых документов", file: "public/docs/targeted_documents_list.pdf" }
          - { title: "Положение о целевой подготовке", file: "public/docs/targeted_training_regulations.pdf" }
          - { title: "Положение о вступительных испытаниях", file: "public/docs/entrance_exam_regulations.pdf" }

      - id = "documents"
        anchor = "documents"
        eyebrow = "// ДОКУМЕНТЫ"
        heading = "Правила и регламенты"
        items:
          - { title: "Правила приёма 2026 (актуальные)", file: "public/docs/admission_rules_2026.pdf" }
          - { title: "Порядок приёма в БГУ 2025",        file: "public/docs/bsu_admission_procedure_2025.pdf" }
          - { title: "Особенности приёма ФРКТ 2025",     file: "public/docs/rcft_admission_features_2025.pdf" }
          - { title: "Категории льготников",              file: "public/docs/preferential_categories.pdf" }
        syllabi_bachelor:
          eyebrow = "Программы первой ступени"
          note = "PDF-ссылки, скачиваемые файлы из public/docs/syllabi/"
          items:
            - "Интеллектуальная электроника"
            - "Кибербезопасность / Безопасность КТиС"
            - "Анализ больших данных и биоинформатика"
            - "Интеллектуальные и киберфизические системы"
            - "Аэрокосмические технологии"
            - "Информатика, программируемая электроника и измерительные системы"
            - "Компьютерное проектирование и технология микроэлектронных систем"
            - "Фотоника и прикладные компьютерные технологии"
            - "Радиофизика и цифровые технологии"
        syllabi_master:
          items:
            - "Аэрокосмические технологии (английский)"
            - "Кибербезопасность (английский)"
            - "Радиофизика и информационные технологии"
            - "Кибербезопасность"

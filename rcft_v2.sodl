  module DepartmentDetailPage:
    route = "/faculty/departments/[slug]"
    file = "src/app/faculty/departments/[slug]/page.tsx"
    content_pattern = "src/content/departments/{slug}.mdx"
    title_template = "{dept_name} — ФРКТ БГУ"
    static_params = ["rdmt","qro","physelnano","ics","kis","teleit","sacm","phaerotech"]
    source_url_pattern = "https://rct.bsu.by/faculty/departments/{slug}"

    content_sub_files:
      note = "Каждый slug имеет дополнительные MDX-файлы в src/content/departments/. Все собраны в одну страницу с табами или аккордеоном."
      pattern_scientific_directions = "src/content/departments/{slug}-scientific-directions.mdx"
      pattern_science               = "src/content/departments/{slug}-science.mdx"
      pattern_staff                 = "src/content/departments/{slug}-staff.mdx"
      pattern_famous_graduates      = "src/content/departments/{slug}-famous-graduates.mdx"
      ics_extra                     = "src/content/departments/ics-competencies.mdx"

    sections_template:
      - "Breadcrumb: Главная / Факультет / Кафедры / {name}"
      - "Заголовок кафедры с eyebrow '// КАФЕДРА'"
      - "Руководитель (фото-placeholder, ФИО, учёная степень, контакт)"
      - "Куратор (ФИО, должность)"
      - "Описание (из {slug}.mdx)"
      - "Табы/аккордеон: Научные направления | Наука | Преподаватели | Известные выпускники"
      - "  - Научные направления: из {slug}-scientific-directions.mdx (teleit — отсутствует, показать заглушку)"
      - "  - Наука: из {slug}-science.mdx"
      - "  - Преподаватели: из {slug}-staff.mdx"
      - "  - Известные выпускники: из {slug}-famous-graduates.mdx"
      - "  - (только ics) Компетенции: из ics-competencies.mdx"
      - "Подраздел: связанные специальности (ссылки на /programs/bachelor/[slug])"

    department_data:
      rdmt:
        name = "Кафедра радиофизики и цифровых медиа технологий"
        head = "Максимович Елена Степановна, Канд. техн. наук"
        curator = "Беленькая Светлана Сергеевна, старший преподаватель"
        source_url = "https://rct.bsu.by/faculty/departments/rdmt"
      qro:
        name = "Кафедра квантовой радиофизики и оптоэлектроники"
        head = "Афоненко Александр Анатольевич, Д-р физ.-мат. наук, профессор"
        curator = "Кадола Елена Вацлафовна, старший преподаватель"
        source_url = "https://rct.bsu.by/faculty/departments/qro"
        conference_contact = "qe@bsu.by, +375 17 282-10-39"
      physelnano:
        name = "Кафедра физической электроники и нанотехнологий"
        head = "Борздов Владимир Михайлович, Д-р физ.-мат. наук, профессор"
        curator = "Василевский Юрий Георгиевич, старший преподаватель"
        source_url = "https://rct.bsu.by/faculty/departments/physelnano"
      ics:
        name = "Кафедра информатики и компьютерных систем"
        head = "Семенович Сергей Николаевич, Канд. техн. наук, доцент"
        curator = "Стецко Игорь Петрович, Канд. техн. наук, доцент"
        source_url = "https://rct.bsu.by/faculty/departments/ics"
      kis:
        name = "Кафедра интеллектуальных систем"
        head = "Козлова Елена Ивановна, Канд. физ.-мат. наук, доцент"
        curator = "Штукаер Дмитрий Сергеевич, старший преподаватель"
        source_url = "https://rct.bsu.by/faculty/departments/kis"
      teleit:
        name = "Кафедра телекоммуникаций и информационных технологий"
        head = "Воротницкий Юрий Иосифович, Канд. физ.-мат. наук, доцент"
        curator = "Попко Елена Евгеньевна, старший преподаватель"

        - { slug: "rphit", track: "rdt",    title: "Радиофизика и цифровые технологии",                                       content_source: "old_site/content/specialties/rdt.md",    image: "/images/specialty_digital_tech.jpg",       head: "Максимович Е.С., Канд. техн. наук",             curator: "Беленькая С.С." }
        - { slug: "ai",    track: "ics",    title: "Интеллектуальные и киберфизические системы",                               content_source: "old_site/content/specialties/ics.md",    image: "/images/specialty_intelligent_systems.jpg",head: "Козлова Е.И., Канд. физ.-мат. наук, доцент",    curator: "Штукаер Д.С." }
        - { slug: "ai",    track: "bd",     title: "Анализ больших данных и биоинформатика",                                   content_source: "old_site/content/specialties/bd.md",     image: "/images/specialty_bioinformatics.jpg",     head: "Яцков Н.Н., Канд. физ.-мат. наук, доцент" }

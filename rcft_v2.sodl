          - { label: "Магистратура 1-й курс Кибербезопасность (англ)",href: "https://docs.google.com/spreadsheets/", external: true }
        note_impl = "Хранить актуальные ссылки в src/content/education.mdx — обновляются вручную"

      - id = "exams"
        anchor = "exams"
        eyebrow = "// РАСПИСАНИЕ СЕССИЙ"
        heading = "Экзаменационные сессии"

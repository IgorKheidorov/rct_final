          - { label: "Задание курсовой работы",            file: "public/docs/coursework_assignment.docx" }
          - { label: "Рекомендации по оформлению",        file: "public/docs/coursework_design_recommendations.pdf" }
          - { label: "Пример оформления ссылок (PDF)",    file: "public/docs/citation_format.pdf" }

      - id = "resources"

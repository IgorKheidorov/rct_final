    sections:
      - id = "schedules"
        anchor = "schedules"
        eyebrow = "// РАСПИСАНИЕ ЗАНЯТИЙ"
        heading = "Расписание"
        note = "Google Sheets ссылки — открываются в новой вкладке, target='_blank'"
        items:
          - { label: "1-й курс",                                      href: "https://docs.google.com/spreadsheets/", external: true }
          - { label: "2-й курс",                                      href: "https://docs.google.com/spreadsheets/", external: true }

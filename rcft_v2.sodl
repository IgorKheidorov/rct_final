          - { label: "Пересдачи (февраль)", file: "public/docs/exams/makeup_feb.pdf" }
          - { label: "Зимняя сессия 1–4 курс", file: "public/docs/exams/winter_session_1_4.pdf" }
        master_winter_2025_2026:
          - { label: "Кибербезопасность 1 курс (англ.)",        file: "public/docs/exams/master_cs1_en.pdf" }
          - { label: "Радиофизика и ИТ 1 курс",                 file: "public/docs/exams/master_rfit1.pdf" }
          - { label: "Кибербезопасность 1 курс",                file: "public/docs/exams/master_cs1.pdf" }
          - { label: "Аэрокосмические технологии 1 курс",       file: "public/docs/exams/master_aero1.pdf" }
          - { label: "Радиофизика и ИТ 2 курс",                 file: "public/docs/exams/master_rfit2.pdf" }
          - { label: "Кибербезопасность 2 курс",                file: "public/docs/exams/master_cs2.pdf" }
          - { label: "Аэрокосмические технологии 2 курс",       file: "public/docs/exams/master_aero2.pdf" }
          - { label: "Аэрокосмика 2 курс (англ.)",              file: "public/docs/exams/master_aero2_en.pdf" }
          - { label: "Кибербезопасность 2 курс (англ.)",        file: "public/docs/exams/master_cs2_en.pdf" }

      - id = "calendar"
        anchor = "calendar"
        eyebrow = "// УЧЕБНЫЙ КАЛЕНДАРЬ 2025–2026"
        heading = "Учебный год"
        bachelor:
          fall_semester:
            teaching: "1 сентября 2025 — 3 января 2026"
            exams: "5–24 января 2026"
            vacation: "26 января — 8 февраля 2026"
          spring_semester:
            teaching: "9 февраля — 6 июня 2026"
            exams: "8–30 июня 2026"
            vacation: "1 июля — 31 августа 2026"
          fourth_year:
            pre_diploma: "2 февраля — 18 апреля 2026"
            diploma_defense: "20 апреля — 30 июня 2026"
        master:
          first_year:
            fall_teaching: "1 сентября — 3 января 2026"
            fall_exams: "5–24 января 2026"
            spring_teaching: "9 февраля — 6 июня 2026"
            spring_exams: "8–30 июня 2026"
          second_year:
            fall_teaching: "1 сентября — 3 января 2026"
            fall_exams: "5–17 января 2026"
            research_internship: "2 февраля — 28 марта 2026"
            thesis: "30 марта — 20 июня 2026"
            defense: "22–30 июня 2026"
          english_programs:
            note = "Кибербезопасность (англ.) и Аэрокосмические технологии (англ.) — отдельный календарь, уточнять на странице"
        phd:
          spring_report: "Апрель 2026"
          fall_report: "Октябрь 2025"
          note: "Отчёты по кафедрам — за 1 месяц до факультетского"

      - id = "documents"
        anchor = "documents"
        eyebrow = "// МЕТОДИЧЕСКИЕ МАТЕРИАЛЫ"
        heading = "Шаблоны и инструкции"
        diploma:
          - { label: "Шаблон дипломной работы (.docx)",   file: "public/docs/diploma_template.docx" }
          - { label: "Инструкция по оформлению (PDF)",     file: "public/docs/diploma_instructions.pdf" }
          - { label: "Шаблон титульного листа (.docx)",    file: "public/docs/diploma_title.docx" }
          - { label: "Задание дипломной работы (.docx)",   file: "public/docs/diploma_assignment.docx" }
          - { label: "Рекомендации по оформлению (PDF)",  file: "public/docs/diploma_design_recommendations.pdf" }

{
  "name": "rcft-bsu",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/retry-next-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "copy-assets": "node scripts/copy-assets.js",
    "migrate-content": "node scripts/migrate-content.js",
    "index-search": "npx pagefind --site out --output-path public/pagefind",
    "build:full": "node scripts/copy-assets.js && node scripts/retry-next-build.mjs && npx pagefind --site out --output-path public/pagefind",
    "validate-links": "npx serve out -p 3000 & npx broken-link-checker http://localhost:3000 -ro"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "framer-motion": "^11.18.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.469.0",
    "next": "14.2.29",
    "next-mdx-remote": "^5.0.0",
    "next-sitemap": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
